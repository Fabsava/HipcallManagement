@model HipcallManagement.DTOs.CreateContactRequest
@{
    ViewData["Title"] = "Yeni Kişi Ekle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0 fw-bold">Yeni Kişi Ekle</h5>
                </div>
                <div class="card-body p-4 bg-white">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <form action="/contacts/new" method="post">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label fw-semibold">Ad <span class="text-danger">*</span></label>
                                <input asp-for="FirstName" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label fw-semibold">Soyad <span class="text-danger">*</span></label>
                                <input asp-for="LastName" class="form-control" required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="JobTitle" class="form-label fw-semibold">Unvan (Job Title)</label>
                                <input asp-for="JobTitle" class="form-control" placeholder="Örn: Co-founder" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="AssignToUserId" class="form-label fw-semibold">Atanacak Kullanıcı ID</label>
                                <div class="input-group">
                                    <input asp-for="AssignToUserId" id="AssignToUserId" class="form-control" type="number" placeholder="ID" />
                                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#userModal" title="Kullanıcı Seç">
                                        <i class="bi bi-three-dots"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="LinkedinUrl" class="form-label fw-semibold">LinkedIn URL</label>
                                <input asp-for="LinkedinUrl" class="form-control" type="url" placeholder="https://linkedin.com/in/..." />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CustomUrl" class="form-label fw-semibold">Özel URL</label>
                                <input asp-for="CustomUrl" class="form-control" type="url" placeholder="https://" />
                            </div>
                        </div>

                        <h6 class="fw-bold border-bottom pb-2 mb-3">İletişim Bilgileri</h6>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">E-Posta Adresi</label>
                                <input name="Emails[0].Email" class="form-control" type="email" placeholder="bill@microsoft.com" />
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Ülke Kodu (Örn: TR, US)</label>
                                <input name="Phones[0].Country" class="form-control" placeholder="TR" />
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-semibold">Telefon Numarası</label>
                                <input name="Phones[0].Number" class="form-control" placeholder="05303422964" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <a href="/contacts" class="btn btn-light border px-4 me-2">İptal</a>
                            <button type="submit" class="btn btn-primary px-4">Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Kullanıcı Seçim Modalı -->
<div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold" id="userModalLabel">
                    <i class="bi bi-person-badge text-success me-2"></i> Atanacak Kullanıcı Seç (Tıklayın veya Çift Tıklayın)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body p-0">
                @{
                    var users = ViewBag.Users as IEnumerable<HipcallManagement.DTOs.UserDto>;
                }
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 80px;">ID</th>
                                <th>Ad Soyad</th>
                                <th>E-Posta</th>
                                <th class="text-end">Eylem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (users != null && users.Any())
                            {
                                foreach (var u in users)
                                {
                                    var uName = !string.IsNullOrEmpty(u.Name) ? u.Name : $"{u.FirstName} {u.LastName}".Trim();
                                    <tr style="cursor: pointer;" onclick="selectUser(@u.Id)" ondblclick="selectUser(@u.Id)">
                                        <td><span class="badge bg-light text-dark border font-monospace">#@u.Id</span></td>
                                        <td class="fw-semibold text-success">@(string.IsNullOrEmpty(uName) ? "-" : uName)</td>
                                        <td class="small text-muted">@u.Email</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-success px-3" onclick="selectUser(@u.Id)">Seç</button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Kullanıcı bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function selectUser(id) {
        document.getElementById('AssignToUserId').value = id;
        var closeBtn = document.querySelector('#userModal .btn-close');
        if (closeBtn) {
            closeBtn.click();
        }
    }
</script>
