@model HipcallManagement.DTOs.ContactDto
@{
    ViewData["Title"] = $"{Model?.FirstName} {Model?.LastName}".Trim();
    var initial = !string.IsNullOrEmpty(Model?.FirstName) ? Model.FirstName.Substring(0, 1).ToUpper() : "K";
    var userName = Model?.User?.FullName ?? Model?.User?.Email;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card-custom">
            <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar-initial bg-success-subtle text-success fs-4" style="width: 52px; height: 52px;">
                        @initial
                    </div>
                    <div>
                        <h4 class="fw-bold text-dark mb-1">@Model?.FirstName @Model?.LastName</h4>
                        @if (!string.IsNullOrEmpty(Model?.JobTitle))
                        {
                            <span class="badge bg-light text-dark border me-2">@Model.JobTitle</span>
                        }
                        <span class="badge bg-light text-secondary border font-monospace">ID: #@Model?.Id</span>
                    </div>
                </div>
                <a href="/contacts" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1">
                    <i class="bi bi-arrow-left"></i> Geri Dön
                </a>
            </div>
            
            <div class="p-4">
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <div class="p-3 bg-light rounded-3 border">
                            <span class="text-muted small d-block mb-1">Atanan Kullanıcı</span>
                            <span class="fw-semibold text-dark fs-6">
                                @if (!string.IsNullOrEmpty(userName))
                                {
                                    <i class="bi bi-person-badge text-success me-1"></i>@userName <small class="text-muted font-monospace">(#@Model?.AssignToUserId)</small>
                                }
                                else if (Model?.AssignToUserId.HasValue == true)
                                {
                                    <span>Kullanıcı ID: #@Model.AssignToUserId</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-link-45deg me-1"></i> Bağlantılar</h6>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item px-0 bg-transparent">
                                <span class="text-muted small d-block">LinkedIn</span>
                                @if (!string.IsNullOrEmpty(Model?.LinkedinUrl))
                                {
                                    <a href="@Model.LinkedinUrl" target="_blank" class="text-decoration-none fw-medium text-primary">
                                        <i class="bi bi-linkedin me-1"></i> Profili İncele
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </li>
                            <li class="list-group-item px-0 bg-transparent">
                                <span class="text-muted small d-block">Özel URL</span>
                                @if (!string.IsNullOrEmpty(Model?.CustomUrl))
                                {
                                    <a href="@Model.CustomUrl" target="_blank" class="text-decoration-none fw-medium text-primary">
                                        <i class="bi bi-globe me-1"></i> @Model.CustomUrl
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </li>
                        </ul>
                    </div>
                </div>

                <hr />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-envelope me-1"></i> E-Posta Adresleri</h6>
                        @if (Model?.Emails != null && Model.Emails.Any())
                        {
                            <div class="d-flex flex-column gap-2">
                                @foreach (var email in Model.Emails)
                                {
                                    <a href="mailto:@email.Email" class="btn btn-light border text-start d-inline-flex align-items-center gap-2">
                                        <i class="bi bi-envelope text-primary"></i> @email.Email
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-muted small">E-posta adresi eklenmemiş.</span>
                        }
                    </div>

                    <div class="col-md-6 mb-3">
                        <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-telephone me-1"></i> Telefon Numaraları</h6>
                        @if (Model?.Phones != null && Model.Phones.Any())
                        {
                            <div class="d-flex flex-column gap-2">
                                @foreach (var phone in Model.Phones)
                                {
                                    <a href="tel:@phone.Number" class="btn btn-light border text-start d-inline-flex align-items-center gap-2">
                                        <span class="badge bg-secondary-subtle text-secondary border">@phone.Country</span>
                                        <i class="bi bi-telephone text-success"></i> @phone.Number
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-muted small">Telefon numarası eklenmemiş.</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
