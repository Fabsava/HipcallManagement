@model IEnumerable<HipcallManagement.DTOs.ContactDto>
@{
    ViewData["Title"] = "Kişiler";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Kişiler</h2>
        <a href="/contacts/new" class="btn btn-primary px-4">Yeni Kişi Ekle</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle border">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Ad Soyad</th>
                    <th>Unvan</th>
                    <th>E-Posta</th>
                    <th>Telefon</th>
                    <th>Şirket ID</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var contact in Model)
                    {
                        var fullName = $"{contact.FirstName} {contact.LastName}".Trim();
                        var email = contact.Emails?.FirstOrDefault()?.Email;
                        var phone = contact.Phones?.FirstOrDefault()?.Number;
                        <tr>
                            <td>@contact.Id</td>
                            <td class="fw-semibold">@(string.IsNullOrEmpty(fullName) ? "-" : fullName)</td>
                            <td>@(string.IsNullOrEmpty(contact.JobTitle) ? "-" : contact.JobTitle)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(email))
                                {
                                    <a href="mailto:@email" class="text-decoration-none">@email</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(phone))
                                {
                                    <a href="tel:@phone" class="text-decoration-none">@phone</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@(contact.CompanyId.HasValue ? contact.CompanyId.Value.ToString() : "-")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Kayıtlı kişi bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
