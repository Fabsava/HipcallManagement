@model HipcallManagement.DTOs.CompanyDto
@{
    ViewData["Title"] = Model?.Name ?? "Şirket Detayı";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0 fw-bold">Şirket Detayı</h5>
                    <a href="/companies" class="btn btn-sm btn-light">Geri Dön</a>
                </div>
                <div class="card-body p-4 bg-white">
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <h3 class="fw-bold text-dark mb-1">@Model?.Name</h3>
                            <span class="badge bg-secondary">ID: @Model?.Id</span>
                        </div>
                        <div class="col-md-4 text-md-end">
                            <span class="text-muted d-block small">Atanan Kullanıcı ID</span>
                            <span class="fw-semibold fs-5">@(Model?.AssignToUserId.HasValue == true ? Model.AssignToUserId.Value.ToString() : "-")</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model?.Description))
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold text-secondary">Açıklama</h6>
                            <p class="border-start border-3 border-primary ps-3 py-2 bg-light rounded-end">@Model.Description</p>
                        </div>
                    }

                    <div class="row mb-4">
                        <div class="col-md-4 mb-2">
                            <h6 class="fw-bold text-secondary">Web Sitesi</h6>
                            @if (!string.IsNullOrEmpty(Model?.WebsiteUrl))
                            {
                                <a href="@Model.WebsiteUrl" target="_blank" class="text-decoration-none fw-semibold">@Model.WebsiteUrl</a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </div>
                        <div class="col-md-4 mb-2">
                            <h6 class="fw-bold text-secondary">LinkedIn</h6>
                            @if (!string.IsNullOrEmpty(Model?.LinkedinUrl))
                            {
                                <a href="@Model.LinkedinUrl" target="_blank" class="text-decoration-none fw-semibold">LinkedIn Profili</a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </div>
                        <div class="col-md-4 mb-2">
                            <h6 class="fw-bold text-secondary">Özel URL</h6>
                            @if (!string.IsNullOrEmpty(Model?.CustomUrl))
                            {
                                <a href="@Model.CustomUrl" target="_blank" class="text-decoration-none fw-semibold">@Model.CustomUrl</a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <h6 class="fw-bold text-secondary mb-3">E-Posta Adresleri</h6>
                            @if (Model?.Emails != null && Model.Emails.Any())
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var email in Model.Emails)
                                    {
                                        <li class="list-group-item px-0 bg-transparent">
                                            <a href="mailto:@email.Email" class="text-decoration-none fw-semibold">@email.Email</a>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">E-posta adresi bulunmuyor.</span>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <h6 class="fw-bold text-secondary mb-3">Telefon Numaraları</h6>
                            @if (Model?.Phones != null && Model.Phones.Any())
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var phone in Model.Phones)
                                    {
                                        <li class="list-group-item px-0 bg-transparent">
                                            <span class="badge bg-light text-dark border me-2">@phone.Country</span>
                                            <a href="tel:@phone.Number" class="text-decoration-none fw-semibold">@phone.Number</a>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">Telefon numarası bulunmuyor.</span>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
