@model HipcallManagement.DTOs.CreateCompanyRequest
@{
    ViewData["Title"] = "Yeni Şirket";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 bg-white rounded">
                    <h3 class="card-title text-dark fw-bold mb-4">Yeni Şirket Ekle</h3>
                    
                    <form asp-action="New" method="post">
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-medium text-dark">Şirket Adı</label>
                            <input asp-for="Name" class="form-control form-control-lg border-secondary-subtle" placeholder="Şirket adını giriniz" required />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 me-md-2">İptal</a>
                            <button type="submit" class="btn btn-primary px-4">Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
