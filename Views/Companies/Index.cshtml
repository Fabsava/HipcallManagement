@model IEnumerable<HipcallManagement.DTOs.CompanyDto>
@{
    ViewData["Title"] = "Şirketler";
}

<div class="container bg-white p-4 rounded shadow-sm mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold m-0">Şirketler</h2>
        <a asp-action="New" class="btn btn-primary px-4">Yeni Ekle</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light">
                <tr>
                    <th class="py-3 px-3">ID</th>
                    <th class="py-3 px-3">Şirket Adı</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var company in Model)
                    {
                        <tr>
                            <td class="text-muted fw-medium px-3">@company.Id</td>
                            <td class="fw-semibold px-3">@company.Name</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2" class="text-center text-muted py-5">Kayıtlı şirket bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
