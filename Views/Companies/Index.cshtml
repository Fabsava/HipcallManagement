@model IEnumerable<HipcallManagement.DTOs.CompanyDto>
@{
    ViewData["Title"] = "Şirketler";
    var totalCount = Model?.Count() ?? 0;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h2 class="fw-bold mb-1 d-flex align-items-center gap-2">
            Şirketler
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill fs-6 px-3 py-1">@totalCount</span>
        </h2>
        <p class="text-muted small mb-0">Hipcall hesabınızda tanımlı şirketlerin listesi</p>
    </div>
    <div>
        <a href="/companies/new" class="btn btn-primary d-inline-flex align-items-center gap-2 px-4 py-2 fw-medium shadow-sm">
            <i class="bi bi-plus-lg fs-6"></i> Yeni Şirket Ekle
        </a>
    </div>
</div>

<div class="card-custom">
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Şirket Adı</th>
                    <th>E-Posta</th>
                    <th>Telefon</th>
                    <th>Web Sitesi</th>
                    <th class="text-end" style="width: 100px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var company in Model)
                    {
                        var primaryEmail = company.Emails?.FirstOrDefault()?.Email;
                        var primaryPhone = company.Phones?.FirstOrDefault()?.Number;
                        <tr>
                            <td>
                                <span class="badge bg-light text-secondary border font-monospace">#@company.Id</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-initial bg-primary-subtle text-primary">
                                        <i class="bi bi-building"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold text-dark">@company.Name</div>
                                        @if (!string.IsNullOrEmpty(company.Description))
                                        {
                                            <div class="text-muted small text-truncate" style="max-width: 250px;">@company.Description</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(primaryEmail))
                                {
                                    <a href="mailto:@primaryEmail" class="text-decoration-none text-dark d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-envelope text-primary"></i> @primaryEmail
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(primaryPhone))
                                {
                                    <a href="tel:@primaryPhone" class="text-decoration-none text-dark d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-telephone text-success"></i> @primaryPhone
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(company.WebsiteUrl))
                                {
                                    <a href="@company.WebsiteUrl" target="_blank" class="btn btn-sm btn-light border text-primary d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-globe"></i> Ziyaret Et
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <a href="/companies/@company.Id" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1">
                                    <i class="bi bi-eye"></i> Detay
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary"></i>
                            Kayıtlı şirket bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
