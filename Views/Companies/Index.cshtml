@model IEnumerable<HipcallManagement.DTOs.CompanyDto>
@{
    ViewData["Title"] = "Şirketler";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Şirketler</h2>
        <a href="/companies/new" class="btn btn-primary">Yeni Şirket Ekle</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle border">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Şirket Adı</th>
                    <th>Açıklama</th>
                    <th>Web Sitesi</th>
                    <th>Kullanıcı ID</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var company in Model)
                    {
                        <tr>
                            <td>@company.Id</td>
                            <td class="fw-semibold">@company.Name</td>
                            <td>@(string.IsNullOrEmpty(company.Description) ? "-" : company.Description)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(company.WebsiteUrl))
                                {
                                    <a href="@company.WebsiteUrl" target="_blank" class="text-decoration-none">Ziyaret Et</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@(company.AssignToUserId.HasValue ? company.AssignToUserId.Value.ToString() : "-")</td>
                            <td class="text-end">
                                <a href="/companies/@company.Id" class="btn btn-sm btn-outline-primary px-3">Detay</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Kayıtlı şirket bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
